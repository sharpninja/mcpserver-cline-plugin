{
  "name": "@sharpninja/mcpserver-cline-plugin",
  "version": "1.0.0",
  "description": "MCP server bridging Cline (VSCode) to McpServer workflow tools — TODO management, session logging, requirements tracking, and GraphRAG knowledge graph",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "mcpserver-cline": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist/",
    "lib/",
    "install.sh",
    "server.json"
  ],
  "keywords": [
    "mcp",
    "cline",
    "mcpserver",
    "todo",
    "session-log",
    "requirements",
    "graphrag",
    "ai-tools"
  ],
  "author": {
    "name": "Payton Byrd (The Sharp Ninja)",
    "url": "https://github.com/sharpninja"
  },
  "license": "MIT",
  "homepage": "https://github.com/sharpninja/mcpserver-cline-plugin",
  "repository": {
    "type": "git",
    "url": "https://github.com/sharpninja/mcpserver-cline-plugin.git"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
